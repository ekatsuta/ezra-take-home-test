# Backend (.NET) configuration for local Docker/compose runs
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8000
JWT__SecretKey=replace-with-a-strong-random-secret-at-least-32-characters
ConnectionStrings__DefaultConnection=Data Source=/app/app.db

# Allowed frontend origins (index-based array syntax for .NET config binding)
CORS__AllowedOrigins__0=http://localhost:3000
CORS__AllowedOrigins__1=http://localhost:5173
